# SIBS Payment Integration Configuration
# Uses direct API key auth (no OAuth2)

# SIBS Payment API URL
SIBS_API_URL=https://api.qly.sibspayments.com/sibs/spg/v2

# API Key credentials
SIBS_CLIENT_ID=your_client_id_here
SIBS_CLIENT_SECRET=your_client_secret_here

# Merchant Configuration
SIBS_ENTITY_ID=your_entity_id_here
SIBS_TERMINAL_ID=your_terminal_id_here

# Webhook Secret (for verifying webhook signatures)
SIBS_WEBHOOK_SECRET=your_webhook_secret_here
